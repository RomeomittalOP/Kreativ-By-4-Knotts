# --- Server ---
PORT=5000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Database (MongoDB) ---
# Leave blank to fall back to JSON flat-file storage in /data
MONGO_URI=mongodb://localhost:27017/4knotts

# --- Auth (JWT) ---
JWT_SECRET=replace-with-32-char-random-string
JWT_EXPIRES_IN=7d

# --- Email (Nodemailer / Gmail App Password) ---
# Generate at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=shubhammittal3555@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM="4 Knotts Kreativ <shubhammittal3555@gmail.com>"
ADMIN_EMAIL=shubhammittal3555@gmail.com

# --- OTP ---
# In dev, OTPs are logged to console + returned in API response.
# Set SMS_PROVIDER=twilio + creds for production phone delivery.
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
